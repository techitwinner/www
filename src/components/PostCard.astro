---
interface Props {
    title: string;
    url: string;
    desc: string;
    date?: string;
    tags?: string[];
}

const { title, url, desc, date, tags, } = Astro.props;
---

<a data-opacity="0.1" href={url} class="card card-outline">
    <div class="content" style="text-overflow:ellipsis;line-clamp:2;">
        <p class="text-xl font-bold">{title}</p>
        <div class="flex flex-row flex-wrap items-center gap-3">
            <p class={date ? 'italic font-mono tracking-tighter opacity-75' : 'hidden'}>{new Date(date).toDateString()}</p>
            <section class="badge" style="font-size:14px;display:flex;flex-direction:row;flex-wrap:wrap;gap:4px;">
                {tags?.map(tag => (
                        <p class="tag">
                            {tag}
                        </p>
                ))}
            </section>
        </div>
        <p style="font-size:16px;">{desc}</p>
    </div>
</a>