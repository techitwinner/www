---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Techit's Space"
	description="Discover about me, Techit Thawiang. Explore my interests, and the unique experiences that shape who I am. Join me on my journey!"
	ogTitle="Techit's Space by Techit Thawiang"
	ogDescription="Explore my projects, skills my interests, and the unique experiences that shape who I am."
	ogUrl="https://techit.win/"
>
	<main>
		<section class="start">
			<div class="container text-white text-center md:text-start">
				<p class="heading mt-64">Hello!</p>
				<p class="text-xl">My name is Techit Thawiang. I do coding, design, gaming, and more.</p>
			</div>
		</section>
		<section class="explore">
			<div class="container text-center md:text-start">
				<h1 class="text-5xl">Explore</h1>
				<p class="text-lg mb-4">Explore through my website, blog posts, about me or how to contact me.</p>
				<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-2">
