</Layout>

<style>
	.start {
		align-items: center;
		display: flex;
		flex-direction: column;
		background-color: rgba(var(--md-sys-color-primary));
		background-image: url("https://files.techit.win/images/background/cristian-palmer-XexawgzYOBc-unsplash.jpg");
		background-position: center;
		background-size: cover;
		color: rgba(var(--md-sys-color-on-primary));
	}
	.explore {
		align-items: center;
		display: flex;
		flex-direction: column;
	}
	.introduce {
		background-color: rgba(var(--md-sys-color-inverse-surface));
		color: rgba(var(--md-sys-color-inverse-on-surface));
		align-items: center;
		display: flex;
		flex-direction: column;
	}
</style>